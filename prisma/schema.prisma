generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                   String    @id @default(cuid())
  accountId            String    @unique
  companyName          String
  contactName          String    @default("")
  address              String    @default("")
  poNumber             String    @default("")
  expectedMonthlyRides Int       @default(0)
  email                String    @default("")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  rides                Ride[]
  invoices             Invoice[]
}

model Ride {
  id              String    @id @default(cuid())
  jobId           String    @default("")
  vehicleNumber   String    @default("")
  pickupLocation  String    @default("")
  dropoffLocation String    @default("")
  passenger       String    @default("")
  driver          String    @default("")
  dateTime        String    @default("")
  amount          Float     @default(0)
  voided          Boolean   @default(false)
  month           String
  year            Int
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  createdAt       DateTime  @default(now())
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber Int           @unique
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  month         String
  year          Int
  amountPreTax  Float
  hst           Float
  total         Float
  notes         String        @default("")
  dateSent      String        @default("")
  dueDate       String        @default("")
  status        InvoiceStatus @default(DRAFT)
  verified      Boolean       @default(false)
  flagged       Boolean       @default(false)
  rides         Ride[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
}

enum TransactionType {
  STAND_RENT
  COMPANY_PAYMENT
  PRODUCT_CHARGE
  INSURANCE
  PAYOUT
  OTHER
}

enum TransactionStatus {
  PAID
  PENDING
  VOID
}

model Broker {
  id              String              @id @default(cuid())
  name            String
  phone           String              @default("")
  billingDay      Int                 @default(1)    // day of month (1–31) when monthly charges auto-generate
  standRentAmount Float               @default(200)  // weekly stand rent base rate per vehicle
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  transactions    BrokerTransaction[]
  vehicles        BrokerVehicle[]
  expenses        BrokerExpense[]
}

model BrokerTransaction {
  id          String            @id @default(cuid())
  brokerId    String
  broker      Broker            @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Float
  description String            @default("")
  dueDate     DateTime?
  paidDate    DateTime?
  status      TransactionStatus @default(PENDING)
  month       Int
  year        Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model BrokerVehicle {
  id              String              @id @default(cuid())
  cabNumber       String
  brokerId        String?
  broker          Broker?             @relation(fields: [brokerId], references: [id], onDelete: SetNull)
  isCompanyCar    Boolean             @default(false)
  insuranceAmount Float               @default(0)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  accidents       VehicleAccident[]
  documents       VehicleDocument[]
}

model VehicleDocument {
  id        String        @id @default(cuid())
  vehicleId String
  vehicle   BrokerVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  label     String        @default("")
  fileName  String
  filePath  String
  fileType  String        @default("")
  fileSize  Int           @default(0)
  createdAt DateTime      @default(now())
}

model VehicleAccident {
  id               String        @id @default(cuid())
  vehicleId        String
  vehicle          BrokerVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date             DateTime
  incidentNumber   String        @default("")
  claimNumber      String        @default("")
  driver           String        @default("")
  settlementAmount Float?
  notes            String        @default("")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model BrokerExpense {
  id          String              @id @default(cuid())
  brokerId    String
  broker      Broker              @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  cabNumber   String              @default("")
  date        DateTime
  amount      Float
  note        String              @default("")
  paid        Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  attachments ExpenseAttachment[]
}

model ExpenseAttachment {
  id        String       @id @default(cuid())
  expenseId String
  expense   BrokerExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  label     String       @default("")
  fileName  String
  filePath  String
  fileType  String       @default("")
  fileSize  Int          @default(0)
  createdAt DateTime     @default(now())
}
