generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                   String    @id @default(cuid())
  accountId            String    @unique
  companyName          String
  contactName          String    @default("")
  address              String    @default("")
  poNumber             String    @default("")
  expectedMonthlyRides Int       @default(0)
  email                String    @default("")
  notes                String    @default("")  // Free-text per-company notes
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  rides                Ride[]
  invoices             Invoice[]
  partyBookings        PartyBooking[]
}

model Ride {
  id              String    @id @default(cuid())
  jobId           String    @default("")
  vehicleNumber   String    @default("")
  pickupLocation  String    @default("")
  dropoffLocation String    @default("")
  passenger       String    @default("")
  customerPhone   String    @default("")
  driver          String    @default("")
  dateTime        String    @default("")
  amount          Float     @default(0)
  voided          Boolean   @default(false)
  month           String
  year            Int
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber Int           @unique
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  month         String
  year          Int
  amountPreTax  Float
  hst           Float
  total         Float
  notes         String        @default("")
  dateSent      String        @default("")
  dueDate       String        @default("")
  status        InvoiceStatus @default(DRAFT)
  verified      Boolean       @default(false)
  flagged       Boolean       @default(false)
  paymentMethod PaymentMethod?
  paymentRef    String        @default("")
  paidDate      DateTime?
  rides         Ride[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
}

enum TransactionType {
  STAND_RENT
  COMPANY_PAYMENT
  PRODUCT_CHARGE
  INSURANCE
  PAYOUT
  OTHER
}

enum TransactionStatus {
  PAID
  PENDING
  VOID
}

enum PaymentMethod {
  DEBIT
  CREDIT
  E_TRANSFER
  CHEQUE
  CASH
  OTHER
}

model Broker {
  id              String              @id @default(cuid())
  name            String
  phone           String              @default("")
  email           String              @default("")
  billingDay      Int                 @default(1)    // day of month (1–31) when monthly charges auto-generate
  standRentAmount Float               @default(200)  // weekly stand rent base rate per vehicle
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  transactions    BrokerTransaction[]
  vehicles        BrokerVehicle[]
  expenses        BrokerExpense[]
  recurringCharges RecurringCharge[]
}

model RecurringCharge {
  id          String            @id @default(cuid())
  brokerId    String
  broker      Broker            @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Float
  description String            @default("")
  dayOfMonth  Int               // 1–31: day when this charge auto-generates
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model BrokerTransaction {
  id            String            @id @default(cuid())
  brokerId      String
  broker        Broker            @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  type          TransactionType
  amount        Float
  description   String            @default("")
  dueDate       DateTime?
  paidDate      DateTime?
  paymentMethod PaymentMethod?
  paymentRef    String            @default("")
  status        TransactionStatus @default(PENDING)
  month         Int
  year          Int
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  attachments   TransactionAttachment[]
}

model TransactionAttachment {
  id            String            @id @default(cuid())
  transactionId String
  transaction   BrokerTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  label         String            @default("")
  fileName      String
  filePath      String
  fileType      String            @default("")
  fileSize      Int               @default(0)
  fileData      Bytes?            // Stored in DB so files survive on serverless filesystems (Vercel is read-only at runtime)
  createdAt     DateTime          @default(now())
}

model BrokerVehicle {
  id              String              @id @default(cuid())
  cabNumber       String
  brokerId        String?
  broker          Broker?             @relation(fields: [brokerId], references: [id], onDelete: SetNull)
  isCompanyCar    Boolean             @default(false)
  insuranceAmount Float               @default(0)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  accidents       VehicleAccident[]
  documents       VehicleDocument[]
}

model VehicleDocument {
  id        String        @id @default(cuid())
  vehicleId String
  vehicle   BrokerVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  label     String        @default("")
  fileName  String
  filePath  String
  fileType  String        @default("")
  fileSize  Int           @default(0)
  fileData  Bytes?        // Stored in DB so files survive on serverless filesystems (Vercel is read-only at runtime)
  createdAt DateTime      @default(now())
}

model VehicleAccident {
  id               String        @id @default(cuid())
  vehicleId        String
  vehicle          BrokerVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date             DateTime
  incidentNumber   String        @default("")
  claimNumber      String        @default("")
  driver           String        @default("")
  settlementAmount Float?
  notes            String        @default("")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model BrokerExpense {
  id          String              @id @default(cuid())
  brokerId    String
  broker      Broker              @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  cabNumber   String              @default("")
  date        DateTime
  amount      Float
  note        String              @default("")
  paid        Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  attachments ExpenseAttachment[]
}

model ExpenseAttachment {
  id        String       @id @default(cuid())
  expenseId String
  expense   BrokerExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  label     String       @default("")
  fileName  String
  filePath  String
  fileType  String       @default("")
  fileSize  Int          @default(0)
  fileData  Bytes?       // Stored in DB so files survive on serverless filesystems (Vercel is read-only at runtime)
  createdAt DateTime     @default(now())
}

// Company-wide expenses — not tied to any broker. Things like office rent,
// utilities, insurance, software subscriptions, advertising, etc.
// Also holds per-vehicle costs (cab repairs) when vehicleNumber is set.
// Feeds the dashboard P&L.
model CompanyExpense {
  id            String                      @id @default(cuid())
  date          DateTime
  amount        Float
  category      String                      @default("OTHER")  // e.g. "Rent", "Utilities", "Insurance", "Cab Repair". Free-text with UI suggestions.
  vehicleNumber String                      @default("")       // optional cab # when the expense is for a specific vehicle (e.g. repair)
  note          String                      @default("")
  paid          Boolean                     @default(false)
  paidDate      DateTime?
  month         Int                         // derived from date, for month/year filtering
  year          Int
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  attachments   CompanyExpenseAttachment[]

  @@index([month, year])
  @@index([date])
  @@index([category])
  @@index([vehicleNumber, month, year])
}

model CompanyExpenseAttachment {
  id        String          @id @default(cuid())
  expenseId String
  expense   CompanyExpense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  label     String          @default("")
  fileName  String
  filePath  String
  fileType  String          @default("")
  fileSize  Int             @default(0)
  fileData  Bytes?          // Stored in DB so files survive on serverless filesystems (Vercel is read-only at runtime)
  createdAt DateTime        @default(now())
}

// ──────────────────────────────────────────────────────────────
// Phase 3: Driver Management & Daily Sheets
// ──────────────────────────────────────────────────────────────

enum Shift {
  MORNING   // 5am – 5pm
  EVENING   // 5pm – 5am
}

enum PayoutStatus {
  DRAFT
  PAID
}

model Driver {
  id            String              @id @default(cuid())
  name          String
  phone         String              @default("")
  email         String              @default("")
  licenseNumber String              @default("")
  isActive      Boolean             @default(true)
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  assignments   VehicleAssignment[]
  dailySheets   DailySheet[]
  payouts       DriverPayout[]
}

// A driver–vehicle–shift assignment. Only one active per (vehicle, shift) at a time.
// Past assignments are kept for history (isActive=false, endDate set).
model VehicleAssignment {
  id            String    @id @default(cuid())
  vehicleNumber String                                   // cab # e.g. "30" — matches BrokerVehicle.cabNumber / Ride.vehicleNumber
  driverId      String
  driver        Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  shift         Shift
  startDate     DateTime
  endDate       DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([vehicleNumber, shift, isActive])
  @@index([driverId, isActive])
}

model DailySheet {
  id                    String    @id @default(cuid())
  driverId              String
  driver                Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicleNumber         String
  date                  DateTime
  shift                 Shift
  grossEarnings         Float     @default(0)
  gasDeduction          Float     @default(0)
  debitFee              Float     @default(0)   // total debit settlement from terminal
  debitTransactionCount Int       @default(0)   // # of debit txns ($1 each, subtracted from debitFee)
  callChargeDeduction   Float     @default(0)
  extraExpenseDeduction Float     @default(0)
  extraExpenseNote      String    @default("")
  hoursWorked           Float     @default(0)   // legacy — no longer collected by the UI
  netDriverPay          Float     @default(0)   // gross × 40% (reference only; driver pay per shift = companyNet)
  companyNet            Float     @default(0)   // driver pay per shift: gross × 60% − (debitFee − txnCount) − gas − call − extra (can be ±)
  payoutPeriod          Int                     // 1 (1–10), 2 (11–20), 3 (21–end) — derived from date
  month                 Int
  year                  Int
  isPaid                Boolean   @default(false)
  paidDate              DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Prevent double-entry of the same driver's shift on the same day — a
  // driver only has one morning sheet and one evening sheet per calendar day.
  @@unique([driverId, date, shift])
  @@index([driverId, month, year])
  @@index([driverId, payoutPeriod, month, year])
  @@index([date])
  @@index([vehicleNumber, date])
}

model DriverPayout {
  id              String       @id @default(cuid())
  driverId        String
  driver          Driver       @relation(fields: [driverId], references: [id], onDelete: Cascade)
  periodStart     DateTime
  periodEnd       DateTime
  payoutPeriod    Int          // 1, 2, or 3
  month           Int
  year            Int
  totalGross      Float        @default(0)
  totalDeductions Float        @default(0)
  totalNetPay     Float        @default(0)
  status          PayoutStatus @default(DRAFT)
  paidDate        DateTime?
  notes           String       @default("")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([driverId, payoutPeriod, month, year])
  @@index([month, year, payoutPeriod])
  @@index([status])
}

// App user: simple username/password login. allowedPages is the list of
// page keys (e.g. "dashboard", "invoices") this user can open. Admins
// have implicit access to everything regardless of allowedPages.
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String   @default("")
  passwordHash String
  isAdmin      Boolean  @default(false)
  allowedPages String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Configurable "From" addresses. The admin adds them here, and then
// anywhere the app sends mail (invoice send/resend, driver report,
// broker statement) the user can pick which sender to use. All
// addresses route through the same SMTP transport (lib/email.ts);
// the SMTP server must permit sending as each address.
model EmailSender {
  id        String   @id @default(cuid())
  label     String                   // e.g. "Accounting"
  email     String   @unique         // e.g. "accounts@vetstaxis.ca"
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDefault])
}

// Audit trail for every outbound email. Shown as "history" on driver /
// broker detail pages and used to drive the "Sent on …" status chip.
model EmailLog {
  id             String   @id @default(cuid())
  recipientType  String                   // "DRIVER" | "BROKER" | "INVOICE"
  recipientId    String                   // driver id / broker id / invoice id
  recipientEmail String
  fromAddress    String                   // the "From" address used
  subject        String
  month          Int?                     // 1-12 (when applicable)
  year           Int?                     // 2024+ (when applicable)
  sentAt         DateTime @default(now())
  sentById       String?                  // User.id of the staff member who clicked Send
  status         String   @default("SENT") // "SENT" | "FAILED"
  error          String   @default("")

  @@index([recipientType, recipientId])
  @@index([recipientType, recipientId, month, year])
  @@index([sentAt])
}

// Singleton: only ever one row (id = "default"). Holds the editable
// parts of the invoice email so the office can change them without
// a deploy. Placeholders supported: {{invoiceNumber}}, {{month}},
// {{year}}, {{companyName}}, {{total}}, {{dueDate}}.
model EmailTemplate {
  id        String   @id @default("default")
  subject   String   @default("Invoice #{{invoiceNumber}} — Rides for {{month}} {{year}}")
  intro     String   @default("Please find your invoice for transportation services provided in {{month}} {{year}} attached to this email as a PDF.")
  closing   String   @default("Please remit payment by the due date indicated above. If you have any questions regarding this invoice, please don't hesitate to reach out.\n\nThank you for your business.")
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────
// Party Bookings — group/event transportation bookings
// ──────────────────────────────────────────────────────────────

enum PartyStatus {
  BOOKED
  CONFIRMED
  COMPLETED
  CANCELLED
}

model PartyBooking {
  id              String      @id @default(cuid())
  customerName    String
  customerPhone   String      @default("")
  customerEmail   String      @default("")
  eventDate       DateTime
  pickupTime      String      @default("")   // e.g. "14:00"
  pickupLocation  String      @default("")
  dropoffLocation String      @default("")
  passengers      Int         @default(1)
  vehiclesNeeded  Int         @default(1)
  quotedAmount    Float       @default(0)
  status          PartyStatus @default(BOOKED)
  notes           String      @default("")
  companyId       String?                    // optional link to a Company for invoicing
  company         Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([eventDate])
  @@index([status])
}

// ──────────────────────────────────────────────────────────────
// Hallcon — predefined routes & trip logging
// ──────────────────────────────────────────────────────────────

model HallconRoute {
  id              String        @id @default(cuid())
  routeName       String        @unique       // e.g. "Timmins → Kapuskasing"
  pickupLocation  String        @default("")
  dropoffLocation String        @default("")
  distanceKm      Float         @default(0)
  driverPay       Float         @default(0)   // what we pay the driver per trip
  billingAmount   Float         @default(0)   // what Hallcon pays us per trip
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  trips           HallconTrip[]
}

model HallconTrip {
  id            String       @id @default(cuid())
  routeId       String
  route         HallconRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  tripNumber    String       @default("")   // free-text, e.g. "T-100"
  date          DateTime
  driver        String       @default("")
  vehicleNumber String       @default("")
  passengers    Int          @default(1)
  duration      String       @default("")   // free-text, e.g. "3 hours"
  driverPay     Float        @default(0)   // copied from route at time of logging (can override)
  billingAmount Float        @default(0)   // copied from route at time of logging (can override)
  notes         String       @default("")
  month         Int
  year          Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([routeId])
  @@index([date])
  @@index([month, year])
  @@index([driver])
}
